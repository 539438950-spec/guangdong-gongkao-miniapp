<view class="page">
  <view class="card" wx:if="{{pageState === 'loading'}}">
    <view class="section-title">首页概览</view>
    <view class="muted">{{pageStatusMessage || '正在加载首页概览...'}}</view>
  </view>

  <view class="card" wx:elif="{{pageState === 'error'}}">
    <view class="section-title">首页概览</view>
    <view class="muted">{{pageStatusMessage || '加载首页概览失败'}}</view>
  </view>

  <view class="card" wx:elif="{{pageState === 'empty'}}">
    <view class="section-title">首页概览</view>
    <view class="muted">{{pageStatusMessage || '当前还没有可展示的首页数据。'}}</view>
  </view>

  <block wx:elif="{{pageState === 'content' || pageState === 'degraded'}}">
  <view class="card" wx:if="{{pageState === 'degraded' && pageStatusMessage}}">
    <view class="section-title">状态提示</view>
    <view class="muted">{{pageStatusMessage}}</view>
  </view>

  <view class="hero">
    <view class="section-title">广东公考信息与选岗工具</view>
    <view>聚焦官方公告、岗位对比和高时效更新。</view>
    <view class="metrics" style="margin-top: 24rpx;">
      <view class="metric">
        <view>{{heroStats.sourceCount}}</view>
        <view class="muted">数据源</view>
      </view>
      <view class="metric">
        <view>{{heroStats.compareGroupCount}}</view>
        <view class="muted">对比方案</view>
      </view>
      <view class="metric">
        <view>{{heroStats.unreadMessageCount}}</view>
        <view class="muted">未读消息</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">核心入口</view>
    <view class="button" bindtap="goToNotices">查看公告与岗位</view>
    <view class="button secondary" style="margin-top: 16rpx;" bindtap="goToCompare">打开岗位对比</view>
    <view class="button secondary" style="margin-top: 16rpx;" bindtap="goToReviewCenter">
      打开复核中心
      <text wx:if="{{reviewSummary.total}}">（{{reviewSummary.total}}）</text>
    </view>
    <view class="button secondary" style="margin-top: 16rpx;" bindtap="goToMessages">
      打开站内消息
      <text wx:if="{{heroStats.unreadMessageCount}}">（{{heroStats.unreadMessageCount}}）</text>
    </view>
  </view>

  <view class="card" wx:if="{{compareWorkspace.active}}">
    <view class="section-title">继续处理对比方案</view>
    <view class="item-title">{{compareWorkspace.groupName}}</view>
    <view class="tag-row" style="margin-top: 12rpx;" wx:if="{{compareWorkspace.tags.length}}">
      <block wx:for="{{compareWorkspace.tags}}" wx:key="*this">
        <view class="tag">{{item}}</view>
      </block>
    </view>
    <view class="muted" wx:if="{{compareWorkspace.headline}}" style="margin-top: 8rpx;">
      {{compareWorkspace.headline}}
    </view>
    <view class="muted" wx:if="{{compareWorkspace.detail}}">
      {{compareWorkspace.detail}}
    </view>
    <view class="muted" wx:if="{{compareWorkspace.updatedAt}}">
      最近处理：{{compareWorkspace.updatedAt}}
    </view>
    <view class="button secondary" style="margin-top: 16rpx;" bindtap="openCompareWorkspace">
      {{compareWorkspace.actionLabel}}
    </view>
  </view>

  <view class="card" wx:if="{{savedFilterWorkspace.active}}">
    <view class="section-title">继续处理筛选方案</view>
    <view class="item-title">{{savedFilterWorkspace.filterName}}</view>
    <view class="tag-row" style="margin-top: 12rpx;" wx:if="{{savedFilterWorkspace.tags.length}}">
      <block wx:for="{{savedFilterWorkspace.tags}}" wx:key="*this">
        <view class="tag">{{item}}</view>
      </block>
    </view>
    <view class="muted" wx:if="{{savedFilterWorkspace.headline}}" style="margin-top: 8rpx;">
      {{savedFilterWorkspace.headline}}
    </view>
    <view class="muted" wx:if="{{savedFilterWorkspace.detail}}">
      {{savedFilterWorkspace.detail}}
    </view>
    <view class="button secondary" style="margin-top: 16rpx;" bindtap="openSavedFilterWorkspace">
      {{savedFilterWorkspace.actionLabel}}
    </view>
  </view>

  <view class="card" wx:if="{{sourceStates.length}}">
    <view class="section-title">发布闸门摘要</view>
    <view class="muted">
      可直接发布 {{sourceSummary.publishableCount}} 个来源，受限 {{sourceSummary.restrictedCount}} 个，
      待复核 {{reviewSummary.total}} 条，阻塞发布 {{reviewSummary.blockingRelease}} 条。
    </view>
    <view class="tag-row" style="margin-top: 12rpx;" wx:if="{{sourceGateFailureTags.length}}">
      <view class="tag">高频失败</view>
      <view class="tag" wx:for="{{sourceGateFailureTags}}" wx:key="label">
        {{item.label}} {{item.count}}
      </view>
    </view>
    <view class="tag-row" style="margin-top: 12rpx;" wx:if="{{reviewFocusTags.length}}">
      <view class="tag">待复核重点</view>
      <view class="tag tag-warn" wx:for="{{reviewFocusTags}}" wx:key="label">
        {{item.label}} {{item.count}}
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{subscriptions.length}}">
    <view class="section-title">订阅提醒</view>
    <block wx:for="{{subscriptions}}" wx:key="id">
      <view class="list-item">
        <view class="item-title">{{item.name}}</view>
        <view class="muted">{{item.summary}}</view>
        <view class="muted" style="margin-top: 8rpx;">
          当前命中 {{item.currentMatchCount}} 个岗位，新增 {{item.newMatchCount}} 个岗位
        </view>
        <view class="muted" wx:if="{{item.decisionSummary}}" style="margin-top: 8rpx;">
          决策摘要：{{item.decisionSummary}}
        </view>
        <view class="muted" wx:if="{{item.firstNewPositionTitle}}" style="margin-top: 8rpx;">
          新增岗位：{{item.firstNewPositionTitle}}
        </view>
        <view class="muted" wx:if="{{item.bestMatchSummary}}" style="margin-top: 8rpx;">
          优先看：{{item.bestMatchSummary}}
        </view>
        <view class="muted" wx:if="{{item.nextActionSummary}}" style="margin-top: 8rpx;">
          下一步：{{item.nextActionSummary}}
        </view>
        <view class="muted" wx:if="{{item.compareHint}}" style="margin-top: 8rpx;">
          对比建议：{{item.compareHint}}
        </view>
        <view class="tag-row" style="margin-top: 12rpx;">
          <view class="button secondary compact-button" data-id="{{item.id}}" data-notice-id="{{item.noticeId}}" bindtap="openSubscription">查看命中岗位</view>
          <view class="button secondary compact-button" data-id="{{item.id}}" bindtap="quickCompareSubscription">
            {{item.compareButtonLabel}}
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="card">
    <view class="section-title">首版关注地区</view>
    <view class="tag-row">
      <block wx:for="{{focusAreas}}" wx:key="*this">
        <view class="tag">{{item}}</view>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="section-title">最新公告</view>
    <block wx:for="{{latestNotices}}" wx:key="id">
      <view class="list-item" data-id="{{item.id}}" bindtap="openLatestNotice">
        <view class="item-title">{{item.title}}</view>
        <view class="tag-row" style="margin-top: 12rpx;">
          <view class="tag {{item.sourceModeTagClass}}">{{item.sourceModeLabel}}</view>
          <view class="tag">{{item.area}}</view>
          <view class="tag">{{item.noticeStageLabel}}</view>
          <view class="tag {{item.availabilityTagClass}}">{{item.availabilityLabel}}</view>
        </view>
        <view class="muted">{{item.source}} · {{item.publishedAt}}</view>
        <trust-card
          wx:if="{{item.noticeTrust}}"
          trust="{{item.noticeTrust}}"
          action="{{item.trustAction}}"
          showCard="{{false}}"
          showTitle="{{false}}"
          showCoverage="{{false}}"
          showWorkbook="{{false}}"
          showFetch="{{false}}"
          showPublish="{{false}}"
          showRun="{{false}}"
          showPublishDetail="{{false}}"
          showRiskSummary="{{false}}"
          bind:actiontap="openTrustRoute"
        />
        <view class="tag-row" style="margin-top: 12rpx;" wx:if="{{item.homePriorityLabel}}">
          <view class="tag {{item.homePriorityTagClass}}">{{item.homePriorityLabel}}</view>
        </view>
        <view class="muted" wx:if="{{item.homePriorityDetail}}">{{item.homePriorityDetail}}</view>
        <view class="tag-row" style="margin-top: 12rpx;" wx:if="{{item.noticeCompareSuggestion.actionLabel}}">
          <view class="tag {{item.noticeCompareTagClass}}">对比建议</view>
          <view class="tag">{{item.noticeCompareSuggestion.actionLabel}}</view>
          <view class="tag" wx:if="{{item.noticeCompareSuggestion.groupName}}">{{item.noticeCompareSuggestion.groupName}}</view>
        </view>
        <view class="muted" wx:if="{{item.noticeCompareSuggestion.hint}}">{{item.noticeCompareSuggestion.hint}}</view>
        <view class="muted" wx:if="{{item.noticeProgressHint}}">{{item.noticeProgressHint}}</view>
        <view class="muted" wx:if="{{item.noticeProgressDetail}}">{{item.noticeProgressDetail}}</view>
        <view class="muted" wx:if="{{item.sourceModeNote}}">{{item.sourceModeNote}}</view>
        <view class="muted" wx:if="{{!item.hasStructuredPositions}}">当前来源仅完成公告解析，先展示公告与附件。</view>
        <view
          class="button"
          style="margin-top: 20rpx;"
          wx:if="{{item.noticeCompareSuggestion.actionLabel}}"
          data-id="{{item.id}}"
          catchtap="quickCompareLatestNotice"
        >
          {{item.noticeCompareSuggestion.actionLabel}}
        </view>
      </view>
    </block>
  </view>

  <view class="card" wx:if="{{sourceStates.length}}">
    <view class="section-title">数据源状态</view>
    <view class="muted">风险来源 {{heroStats.sourceAlertCount}} 个，超时未更新 {{heroStats.overdueSourceCount}} 个，待复核 {{heroStats.pendingReviewTotal}} 条，最近告警 {{heroStats.alertEventCount}} 条。</view>
    <view class="button secondary" style="margin-top: 16rpx;" bindtap="goToSourceStatus">查看完整状态</view>
    <block wx:for="{{sourceStates}}" wx:key="sourceId">
      <view class="list-item">
        <view class="item-title">{{item.sourceName}}</view>
        <view class="tag-row" style="margin-top: 12rpx;">
          <view class="tag {{item.sourceModeTagClass}}">{{item.sourceModeLabel}}</view>
          <view class="tag {{item.publishGateTagClass}}" wx:if="{{item.publishGate && item.publishGate.label}}">
            {{item.publishGate.label}}
          </view>
        </view>
        <view class="muted">轮询 {{item.scheduleMinutes || 30}} 分钟 · SLA {{item.publishSlaMinutes || 60}} 分钟 · {{item.slaStatusLabel}}</view>
        <view class="muted">最近抓取尝试：{{item.lastFetchedAt || '暂无'}}</view>
        <view class="muted">最近成功抓取：{{item.lastSuccessfulFetchedAt || '暂无'}}</view>
        <view class="muted">最近发布：{{item.lastPublishedAt || '暂无'}}</view>
        <view class="muted">运行状态：{{item.runStatusSummary}}</view>
        <view class="muted" wx:if="{{item.publishGate && item.publishGate.detail}}">发布说明：{{item.publishGate.detail}}</view>
        <view class="muted" wx:if="{{item.riskSummary && item.riskSummary.detail}}">风险摘要：{{item.riskSummary.detail}}</view>
        <view class="muted" wx:if="{{item.gateCheckSummary && item.gateCheckSummary.summary}}">校验摘要：{{item.gateCheckSummary.summary}}</view>
        <view class="muted" wx:if="{{item.nextAction && item.nextAction.label}}">
          下一步：{{item.nextAction.label}}{{item.nextAction.detail ? ' · ' + item.nextAction.detail : ''}}
        </view>
        <view class="muted" wx:if="{{item.sourceModeNote}}">说明：{{item.sourceModeNote}}</view>
        <view class="muted" wx:if="{{item.structureAlert}}">
          结构告警：{{item.structureChangeSummary || '来源页面结构发生变化'}}
        </view>
        <view class="muted" wx:if="{{item.lastErrorSummary}}">最近错误：{{item.lastErrorSummary}}</view>
      </view>
    </block>
  </view>
</block>
</view>
